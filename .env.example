# ================================================================================
# SECRETS ROTATION CHECKLIST — Before Production Deployment
# ================================================================================
# These secrets must be rotated and validated in production environments:
#
# 1. NEXTAUTH_SECRET
#    - Generate fresh: openssl rand -base64 32
#    - Set in Vercel dashboard Env Vars
#    - Invalidates all existing NextAuth sessions (users will re-login)
#
# 2. ADMIN_SECRET
#    - Set a strong random value unique to production
#    - Store ONLY in Vercel dashboard, never in git
#    - Controls /admin panel access
#
# 3. ENCRYPTION_KEY
#    - Generate fresh: openssl rand -hex 32  (64 hex chars = 32 bytes)
#    - Encrypts POS API keys and payment credentials stored in DB
#    - Rotating invalidates stored encrypted values — re-save integrations
#
# 4. DATABASE_URL
#    - Verify connection to production Supabase project
#    - Use Transaction Pooler URL (port 6543, ?pgbouncer=true) on Vercel
#    - Rotate password in Supabase dashboard if compromised
#
# 5. CRON_SECRET
#    - Generate fresh: openssl rand -hex 32
#    - Set in Vercel dashboard Env Vars
#    - Protects /api/cron/* endpoints
#
# 6. UPSTASH_REDIS_REST_TOKEN
#    - Rotate at console.upstash.com after Sprint 1
#    - Controls distributed rate limiting for payment endpoints
#    - Replaces in-memory rate limiter across serverless instances
#
# Notes:
#   - NEXT_PUBLIC_* variables ARE safe to expose in client code
#   - Never commit actual secrets to version control
#   - Use .env.local for local development (gitignored)
# ================================================================================

# Supabase PostgreSQL
# DATABASE_URL → Transaction Pooler (port 6543, ?pgbouncer=true) — used by the app on Vercel.
# DIRECT_URL   → Direct connection (db.[ref].supabase.co:5432) — used ONLY by Prisma CLI
#                (migrate deploy, db push, db pull). Bypasses PgBouncer so migrations work.
# Both are required. See: https://www.prisma.io/docs/guides/database/supabase
DATABASE_URL="postgresql://postgres.YOUR_PROJECT_REF:YOUR_PASSWORD@aws-1-us-west-2.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres"

# Seed mode: "full" (local demo data) or "minimal" (prod-safe: Mesita Demo + owner only)
# Production: npm run db:seed:minimal
SEED_MODE="full"

# Auth.js — generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# Super-admin panel protection
ADMIN_SECRET="your-admin-secret-here"

# AES-256 encryption for credentials stored in DB (POS keys, payment private keys)
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY="your-64-char-hex-key-here"

# Payment provider: STUB (sandbox/demo) or DINERS (production card gateway)
PAYMENT_PROVIDER="STUB"

# Public app URL — the ONLY QR-origin source (Relay 01, product truth #9).
# Production value: https://mesita-app.vercel.app
# Preview deployments: override per-environment in Vercel (Preview scope) with
# the deployment URL so preview QRs stay inside the preview.
# https://mesitademo-two.vercel.app remains the OLD behavioral baseline only —
# do not encode it into new permanent QRs.
NEXT_PUBLIC_APP_URL="https://mesita-app.vercel.app"
NEXT_PUBLIC_DEMO_PAY_URL="https://mesita-app.vercel.app/pay/demo"

# Supabase (for future client-side use)
NEXT_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key-here"

# Vercel Cron authentication (set automatically by Vercel in production)
# Generate with: openssl rand -hex 32
CRON_SECRET="your-cron-secret-here"

# Dev-only auto-login backdoor (/api/dev-login).
# WARNING: NEVER set this in production or any deployed environment.
# The route only activates when this is exactly "true" AND NODE_ENV is "development".
# Leave unset everywhere except a local developer machine.
ENABLE_DEV_LOGIN=""

# Upstash Redis — required for distributed rate limiting across serverless instances.
# Without this the payment endpoint rate limiter is in-memory (per-instance only).
# Create a database at https://console.upstash.com and copy the REST URL + token.
UPSTASH_REDIS_REST_URL="https://YOUR_DB.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-upstash-token-here"

# POS Mesita (Vercel) — demo-only companion endpoints (Table 12 experience).
# Production Contífico integration does NOT use these — see CONTIFICO_* below.
# Swagger: https://mesita-pos.vercel.app/sistema/api/v1/docs
POS_MESITA_API_URL="https://mesita-pos.vercel.app/sistema/api/v1"
# Must match the API_KEY env var of the Mesita-POS deployment — set a real
# value only in .env.local / Vercel, never here.
POS_MESITA_API_KEY="your-pos-api-key-here"

# ── Contífico v2 (frozen contract — contracts/contifico-v2/README.md) ─────────
# Base-URL override for the ONE Contífico adapter. Point it at a Mesita POS
# deployment's /sistema/api/v2 to run against the simulator; leave unset to use
# the environment presets (sandbox/production). Configuration is the ONLY
# switch between simulator and real Contífico — never code.
CONTIFICO_BASE_URL=""
# Smoke-test credentials (scripts/test-contifico.mjs). Never hardcode.
CONTIFICO_API_KEY="your-contifico-api-key-here"
CONTIFICO_TABLE_FIELD="adicional1"
# Persona create + documento cliente attach are UNVERIFIED against the real
# sandbox — opt-in only ("1" to enable). Default off: cobros register against
# the document's existing cliente.
CONTIFICO_ATTACH_CLIENTE=""

# ── Sentry (Relay 02, Phase 4) ─────────────────────────────────────────────
# DSN is NOT secret (it only accepts writes to this project) but keep the
# test/prod projects separate — never point a preview at the prod DSN.
# NEXT_PUBLIC_ prefix is required so the CLIENT-side SDK (instrumentation-client.ts)
# can read it in the browser bundle.
NEXT_PUBLIC_SENTRY_DSN=""
# Build-time only — used by @sentry/nextjs to upload source maps for readable
# stack traces. Set in Vercel as a build-time secret; leave unset locally
# (builds still succeed without it, traces just stay minified).
SENTRY_AUTH_TOKEN=""
SENTRY_ORG="mesitaqr"
SENTRY_PROJECT="mesita-app"
