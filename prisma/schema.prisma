// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  // In serverless (Vercel) point DATABASE_URL at the PgBouncer transaction-mode
  // pooler (port 6543, ?pgbouncer=true) and DIRECT_URL at the session pooler
  // (port 5432). Prisma CLI (migrate/db pull/push) always uses DIRECT_URL.
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// Restaurant: Core tenant entity
model Restaurant {
  id              String           @id @default(uuid())
  name            String           @unique
  // URL-safe slug for dashboard/POS routing (e.g. "la-dona-pepa").
  // Nullable for backwards-compat; fill on creation going forward.
  slug            String?          @unique
  logo            String?          @db.Text
  address         String?          @db.Text
  status          RestaurantStatus @default(PENDING)
  plan            String?
  facturaCount    Int              @default(0)
  ruc             String?
  contactEmail    String?
  phone           String?
  invoiceSequence Int              @default(0)
  // IANA timezone — drives day-boundary for reports and end-of-day exports.
  timezone        String           @default("America/Guayaquil")
  // ISO 4217 currency code. Ecuador is USD; kept explicit for future expansion.
  currency        String           @default("USD")

  // Fiscal / SRI fields (Ecuador e-invoicing via Dátil)
  razonSocial           String?  @db.Text
  nombreComercial       String?
  direccionMatriz       String?  @db.Text
  establecimientoCodigo String?
  puntoEmisionCodigo    String?
  regimen               String?
  obligadoContabilidad  Boolean? @default(false)
  contribuyenteEspecial String?

  // Payment integration (STUB sandbox / Diners production)
  paymentsEnabled       Boolean     @default(false)
  invoiceMode           InvoiceMode @default(DISABLED)
  paymentProvider       String      @default("STUB") // STUB | DINERS
  paymentEnvironment    String      @default("SANDBOX")
  paymentPrivateKeyEnc  String?
  paymentPublicKey      String?

  // POS integration (Contífico / Siigo)
  posProvider      String? // e.g. "CONTIFICO"; null when POS disabled
  posApiKeyEnc     String? @db.Text // AES-256 encrypted; never plaintext
  posEnvironment   String  @default("SANDBOX")
  posTableField    String? // document field carrying the table identifier (configurable)
  posPaymentMethod String? @default("EF") // Contífico `forma_cobro` for /cobro/; set to "TC" once card/tipo_ping is confirmed

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  users      User[]
  tables     Table[]
  categories Category[]
  menuItems  MenuItem[]
  bills      Bill[]
  billItems  BillItem[]
  payments   Payment[]

  @@map("restaurants")
}

enum RestaurantStatus {
  PENDING
  ACTIVE
  SUSPENDED
}

enum InvoiceMode {
  DISABLED
  MANUAL
  POS
}

// User: Staff members with roles
model User {
  id                 String     @id @default(uuid())
  name               String
  email              String     @unique
  password           String
  role               UserRole
  restaurantId       String
  restaurant         Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  mustChangePassword Boolean    @default(false)
  sessions           Session[]
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt

  // Global unique on email for Phase 1 (supports multi-restaurant later with composite unique)
  @@index([restaurantId])
  @@map("users")
}

enum UserRole {
  OWNER
  MANAGER
  SERVER
}

// Bill: Restaurant bills with status tracking
enum BillStatus {
  UNPAID
  PARTIALLY_PAID
  FULLY_PAID
  REFUNDED
}

// Bill split modes for guest payment
enum SplitMode {
  FULL
  EQUAL
  BY_ITEM
}

// Table: Dining tables with QR tokens
model Table {
  id            String     @id @default(uuid())
  name          String
  token         String     @unique
  restaurantId  String
  restaurant    Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  posExternalId String? // POS table identifier for ingestion mapping (D-05)
  bills         Bill[]
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  @@index([restaurantId])
  @@index([restaurantId, posExternalId])
  @@map("tables")
}

// Bill: Restaurant bills with status tracking and split modes
model Bill {
  id                        String       @id @default(uuid())
  tableId                   String
  table                     Table        @relation(fields: [tableId], references: [id], onDelete: Cascade)
  restaurantId              String
  restaurant                Restaurant   @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  status                    BillStatus   @default(UNPAID)
  splitMode                 SplitMode?
  equalSplitPeople          Int?
  equalSharesPaid           Int          @default(0)
  notes                     String?      @db.Text
  posDocumentId             String?      @unique // POS source document id; @unique enforces idempotent ingestion (D-04)
  posToken                  String?              // Contífico `pos` UUID — required for cobros; null = manually created doc (cobro will fail)
  // POS-authoritative totals (D-07) — mirrored verbatim from the POS document at ingestion.
  // When posTotal is non-null it is the source of truth for ALL total/remaining-balance math
  // (never recompute via TAX_MULTIPLIER); cobros must sum EXACTLY to posTotal for PRE→FAC.
  posSubtotal               Decimal?     @db.Decimal(10, 2)
  posIva                    Decimal?     @db.Decimal(10, 2)
  posPropina                Decimal?     @db.Decimal(10, 2)
  posTotal                  Decimal?     @db.Decimal(10, 2)
  invoiceRecipientPaymentId String? // SRI $50 rule — first Payment with valid guestData wins; factura issued to this guest (D-10, Gap #2)
  createdAt                 DateTime     @default(now())
  updatedAt                 DateTime     @updatedAt
  closedAt                  DateTime?
  items         BillItem[]
  payments      Payment[]
  guestSessions BillGuestSession[]
  itemClaims    BillItemClaim[]

  // (restaurantId, status, createdAt) — dashboard: filter by status + date range.
  // Replaces the narrower (restaurantId, status) — the extra column is free for
  // queries that only filter on status, and unlocks date-range without a second scan.
  @@index([restaurantId, status, createdAt])
  // (restaurantId, createdAt) — dashboard end-of-day / revenue reports: all bills in a date window.
  @@index([restaurantId, createdAt])
  // (tableId, status) — POS "get open bill for this table" (hot path, runs on every QR scan).
  @@index([tableId, status])
  @@map("bills")
}

// Category: Menu categories
model Category {
  id           String     @id @default(uuid())
  name         String
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  order        Int        @default(0)
  menuItems    MenuItem[]
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([restaurantId])
  @@map("categories")
}

// MenuItem: Individual menu items
model MenuItem {
  id           String     @id @default(uuid())
  name         String
  price        Decimal    @db.Decimal(10, 2)
  available    Boolean    @default(true)
  categoryId   String
  category     Category   @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  billItems    BillItem[]
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([restaurantId])
  @@index([categoryId])
  @@map("menu_items")
}

// BillItem: Individual items in a bill with price snapshot
model BillItem {
  id           String     @id @default(uuid())
  billId       String
  bill         Bill       @relation(fields: [billId], references: [id], onDelete: Cascade)
  menuItemId   String?
  menuItem     MenuItem?  @relation(fields: [menuItemId], references: [id], onDelete: SetNull)
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  name         String
  price        Decimal    @db.Decimal(10, 2)
  quantity     Int        @default(1)
  isPaid       Boolean    @default(false)
  paidAt       DateTime?
  version      Int        @default(1)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  claims       BillItemClaim[]
  paymentItems PaymentBillItem[]

  @@index([billId])
  @@index([restaurantId])
  @@map("bill_items")
}

// PaymentStatus: Payment completion status
enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum GuestSessionStatus {
  SELECTING
  REVIEWING
  IN_PAYMENT
  PAID
  LEFT
}

enum BillItemClaimStatus {
  ACTIVE
  PAID
  RELEASED
}

model BillGuestSession {
  id          String             @id @default(uuid())
  billId      String
  bill        Bill               @relation(fields: [billId], references: [id], onDelete: Cascade)
  label       String             // P1, P2, P3... assigned per bill/table session
  displayName String
  colorHue    Int
  status      GuestSessionStatus @default(SELECTING)
  joinedAt    DateTime           @default(now())
  lastSeenAt  DateTime           @default(now())
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  claims   BillItemClaim[]
  payments Payment[]

  @@unique([billId, label])
  @@index([billId, status])
  @@map("bill_guest_sessions")
}

model BillItemClaim {
  id             String              @id @default(uuid())
  billId         String
  bill           Bill                @relation(fields: [billId], references: [id], onDelete: Cascade)
  billItemId     String
  billItem       BillItem            @relation(fields: [billItemId], references: [id], onDelete: Cascade)
  guestSessionId String
  guestSession   BillGuestSession    @relation(fields: [guestSessionId], references: [id], onDelete: Cascade)
  units          Decimal             @default(1) @db.Decimal(10, 3)
  status         BillItemClaimStatus @default(ACTIVE)
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  @@unique([billItemId, guestSessionId])
  @@index([billId, status])
  @@index([guestSessionId])
  @@map("bill_item_claims")
}

// Payment: Card charge records with idempotency key
model Payment {
  id                    String            @id @default(uuid())
  billId                String
  bill                  Bill              @relation(fields: [billId], references: [id], onDelete: Cascade)
  restaurantId          String
  restaurant            Restaurant        @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  amount                Decimal           @db.Decimal(10, 2)
  voluntaryTip          Decimal?          @db.Decimal(10, 2)
  providerTransactionId String
  idempotencyKey        String            @unique
  status                PaymentStatus
  splitMode             SplitMode?
  guestSessionId        String?
  guestSession          BillGuestSession? @relation(fields: [guestSessionId], references: [id], onDelete: SetNull)
  equalSplitPeople      Int?
  // Guest invoicing snapshot — frozen on the Payment so we don't depend on a join (SRI $50 rule)
  guestIdentificacion   String?
  guestEmail            String?
  guestNombre           String?
  guestTipo             String? // "CEDULA" | "RUC" | "PASAPORTE" | "CONSUMIDOR_FINAL"
  posRegisteredAt       DateTime?
  posRegisteredByUserId String?
  posRegistrationNote   String?           @db.Text
  paymentItems          PaymentBillItem[]
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt

  @@index([restaurantId, createdAt])
  @@index([restaurantId, posRegisteredAt])
  @@index([billId])
  @@index([guestSessionId])
  @@index([providerTransactionId])
  @@map("payments")
}

model PaymentBillItem {
  id         String    @id @default(uuid())
  paymentId  String
  payment    Payment   @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  billItemId String?
  billItem   BillItem? @relation(fields: [billItemId], references: [id], onDelete: SetNull)
  name       String
  units      Decimal   @default(1) @db.Decimal(10, 3)
  unitPrice  Decimal   @db.Decimal(10, 2)
  amount     Decimal   @db.Decimal(10, 2)
  createdAt  DateTime  @default(now())

  @@index([paymentId])
  @@index([billItemId])
  @@map("payment_bill_items")
}

// Auth.js adapter models (from @auth/prisma-adapter)
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  restaurantId String?
  role         String?

  @@index([userId])
  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}
